# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql://rfq_user:changeme@localhost:5432/rfq_manager_db

# ── Application ───────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# ── Authentication / IAM ──────────────────────────
IAM_SERVICE_URL=http://localhost:8001/iam/v1
JWT_SECRET=change-me-in-production

# ── Event Bus ─────────────────────────────────────
EVENT_BUS_URL=http://localhost:8002/events/v1

# ── File Storage ──────────────────────────────────
FILE_STORAGE_PATH=./uploads
# AZURE_BLOB_CONNECTION_STRING=  # uncomment for Azure Blob Storage

# ── CORS ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
